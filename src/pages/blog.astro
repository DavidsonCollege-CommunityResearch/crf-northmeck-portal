---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/*$/, '/');
const allPosts = await getCollection('blog');
const bySlug = Object.fromEntries(allPosts.map(p => [p.id, p]));

// Curated homepage/teaser order (matches the site's original hand-authored order,
// not chronological).
const ORDER = [
  'why-it-now-takes-31-an-hour',
  'black-renters-cost-burdened',
  'eviction-filings-explained',
  'racial-makeup-schools',
  'neighborhoods-left-out-of-data',
];
const posts = ORDER.map(id => bySlug[id]).filter(Boolean);
---
<BaseLayout title="Stories · North Meck Insights">

<div class="page active" style="display:block">

  <div class="wrap"><div class="crumb"><a onclick={`window.location='${base}index.html'`}>Home</a><i class="ti ti-chevron-right"></i><span>Stories</span></div></div>
  <section class="section"><div class="wrap">
    <div class="sec-head"><span class="eyebrow" style="font-size:15px">Stories</span><h2 class="sec-h" style="font-size:32px">Research in plain English</h2><p class="lead">Short posts for North Meck residents that are clear, brief, and jargon-free.</p></div>
    <div class="blog-grid">
      {posts.map(post => (
        post.data.draft
          ? <article class="bcard" onclick={`window.location='${base}blog.html'`}><div class="bcard-thumb ph"><i class={`ti ${post.data.thumbnailIcon}`}></i><span>{post.data.tag} post thumbnail</span></div><span class="bcard-tag" style="font-size:13px">{post.data.tag}</span><h3 class="bcard-t">{post.data.title}</h3><div class="bcard-meta">{post.data.date.toLocaleDateString('en-US', { month: 'long', year: 'numeric', timeZone: 'UTC' })} · {post.data.readTime}</div></article>
          : <article class="bcard" id={`post-${post.id}`} onclick={`window.location='${base}blog-${post.id}.html'`}><div class="bcard-thumb ph"><i class={`ti ${post.data.thumbnailIcon}`}></i><span>{post.data.tag} post thumbnail</span></div><span class="bcard-tag" style="font-size:13px">{post.data.tag}</span><h3 class="bcard-t">{post.data.title}</h3><div class="bcard-meta">{post.data.date.toLocaleDateString('en-US', { month: 'long', year: 'numeric', timeZone: 'UTC' })} · {post.data.readTime}</div></article>
      ))}
    </div>
  </div></section>

</div>
</BaseLayout>
