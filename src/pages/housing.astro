---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/*$/, '/');
---
<BaseLayout title="Housing · North Meck Insights">

<div class="page active" style="display:block">

  <div class="wrap">
    <div class="crumb"><a onclick={`window.location='${base}index.html'`}>Home</a><i class="ti ti-chevron-right"></i><span>Housing</span></div>
    <div class="dash-hero" style="margin-bottom:56px">
      <div class="split" style="align-items:flex-start">
        <div>
          <span class="eyebrow" style="font-size:15px">Housing affordability</span>
          <h1 class="dash-h1">Can people afford to live in North Meck?</h1>
          <p class="lead dash-lead" style="margin-bottom:0">Rents have risen twice as fast as incomes since 2018. Home values have nearly doubled. This section follows the data to show who is affected, where the pressure is highest, and what it means for the communities that make North Meck work.</p>
        </div>
        <img src="images/housing-hero.jpg" alt="A North Meck neighborhood street with a For Rent sign" style="width:100%;max-height:320px;object-fit:cover;border-radius:var(--rl);display:block">
      </div>
    </div>
    <div class="tabs" id="housing-tabs">
      <span class="tab active" data-tab="overview" onclick="setTab(this)">Overview</span>
      <span class="tab" data-tab="affordability" onclick="setTab(this)">Affordability</span>
      <span class="tab" data-tab="supply" onclick="setTab(this)">Supply</span>
      <span class="tab" data-tab="displacement" onclick="setTab(this)">Displacement Risk</span>
      <span class="tab" data-tab="homeownership" onclick="setTab(this)">Homeownership &amp; Equity</span>
      <span class="tab" data-tab="income" onclick="setTab(this)">Income &amp; Need</span>
    </div>
  </div>
  <div class="wrap dash-filter">
    <div class="filterbar">
      <span class="lbl">Area:</span>
      <span class="chip on" onclick="setChip(this)">All North Meck</span>
      <span class="chip" onclick="setChip(this)">Cornelius</span>
      <span class="chip" onclick="setChip(this)">Davidson</span>
      <span class="chip" onclick="setChip(this)">Huntersville</span>
      <span class="hint">filters every chart</span>
    </div>
  </div>

  <!-- TAB: overview -->
  <div class="tabpane active" data-pane="overview">
    <div class="wrap">

      <!-- Overview: 4 spotlight fact rows -->
      <div class="stat-rows" style="margin-bottom:48px" id="ov-fact-rows">

        <!-- Fact 1: 52% rent rise -->
        <div class="stat-row">
          <div class="srow-fig">
            <div class="stat-n warn">52%</div>
            <p class="stat-l">rent rise in Huntersville since 2018, from $1,196 to $1,820/mo</p>
            <span class="stat-src"><span class="gloss-link" data-term="acs" role="button" tabindex="0" onclick="glossTerm('acs')">ACS</span> 2018–2024</span>
          </div>
          <div class="card viz-host">
            <div class="card-t">Median Rent by Town (2018–2024)</div>
            <div class="card-s"></div>
            <div id="ovf-rent" style="width:100%"></div>
          </div>
        </div>

        <!-- Fact 2: 20+ years -->
        <div class="stat-row">
          <div class="srow-fig">
            <div class="stat-n warn">20+ yrs</div>
            <p class="stat-l">of gross income to buy the median home, for a $20k–$35k household</p>
            <span class="stat-src"><span class="gloss-link" data-term="acs" role="button" tabindex="0" onclick="glossTerm('acs')">ACS</span> 2024</span>
          </div>
          <div class="card viz-host">
            <div class="card-t">Years of Income to Buy the Median Home, by Bracket (2024)</div>
            <div class="card-s"></div>
            <div id="ovf-ptr" style="width:100%"></div>
          </div>
        </div>

        <!-- Fact 3: $693k -->
        <div class="stat-row">
          <div class="srow-fig">
            <div class="stat-n"><span class="cur">$</span>693k</div>
            <p class="stat-l">median home price in Davidson, 4× the U.S. national median</p>
            <span class="stat-src"><span class="gloss-link" data-term="acs" role="button" tabindex="0" onclick="glossTerm('acs')">ACS</span> 2024</span>
          </div>
          <div class="card viz-host">
            <div class="card-t">Median Home Value by Town vs. U.S. Median (2024)</div>
            <div class="card-s">U.S. median ~$179k</div>
            <div id="ovf-home" style="width:100%"></div>
          </div>
        </div>

        <!-- Fact 4: ~10 years -->
        <div class="stat-row">
          <div class="srow-fig">
            <div class="stat-n">~10 yrs</div>
            <p class="stat-l">to save a 20% down payment at a 10% annual savings rate</p>
            <span class="stat-src"><span class="gloss-link" data-term="acs" role="button" tabindex="0" onclick="glossTerm('acs')">ACS</span> 2024</span>
          </div>
          <div class="card viz-host">
            <div class="card-t">Years to Save a 20% Down Payment, by Town (2024)</div>
            <div class="card-s">Assumes 10% annual savings rate on median household income</div>
            <div id="ovf-dp" style="width:100%"></div>
          </div>
        </div>

      </div>


      <!-- Overview hero chart: Rent vs. Income indexed -->
      <div class="card viz-host" id="income-rent-chart-host" style="margin-bottom:24px">
        <div class="card-t">Rent vs. Income Growth, Indexed to 2018</div>
        <div class="card-s">When the rent line rises above the income line, affordability is eroding · North Mecklenburg</div>
        <div class="filterbar" style="margin-bottom:14px">
          <span class="lbl">Town:</span>
          <button class="chip on" data-rent-town="All">All towns</button>
          <button class="chip" data-rent-town="Cornelius">Cornelius</button>
          <button class="chip" data-rent-town="Davidson">Davidson</button>
          <button class="chip" data-rent-town="Huntersville">Huntersville</button>
        </div>
        <div id="income-rent-chart" style="width:100%"></div>
        <div class="callout warn"><div class="callout-t">In Davidson, rents rose 68% between 2018 and 2024 while incomes rose 37%. The gap is widest here, but every town shows the same divergence.</div><div class="callout-s">Source: <span class="gloss-link" data-term="acs" role="button" tabindex="0" onclick="glossTerm('acs')">ACS</span> 2018–2024 · index set to 100 in 2018 so towns can be compared on the same scale regardless of starting dollar values</div></div>
      </div>

      <div class="g2" style="margin-top:8px">
        <div class="callout info">
          <div class="callout-t"><strong>The story behind the numbers:</strong> North Meck's three towns look wealthy on the surface: median incomes of $113K–$156K and homeownership above 70% read as prosperity. But that aggregate picture conceals deep pressure on renters, low-income households, and communities of color who keep these towns running.</div>
          <div class="callout-s">Explore each tab to see who is affected, where the pressure is highest, and what it means for communities like Davidson West.</div>
        </div>
        <div class="map-ph">
          <i class="ti ti-map-2"></i>
          <div class="t">Cost burden by neighborhood</div>
          <div class="s">Choropleth map · click a neighborhood to filter every chart</div>
          <div class="scale"></div>
          <div class="scale-lbl">low → high cost burden · Viridis · alt text provided</div>
        </div>
      </div>
    </div>
  </div>

  <!-- TAB: affordability -->
  <div class="tabpane" data-pane="affordability">
    <div class="wrap">
      <div class="sec-head"><span class="eyebrow">Affordability</span><h2 class="sec-h">How much does it actually cost to live here, and who can afford it?</h2></div>

      <!-- Block 1: Rents over time -->
      <div style="margin-bottom:36px">
        <h3 style="font-family:'Newsreader',serif;font-size:22px;font-weight:400;margin-bottom:6px;color:var(--ink)">How have rents changed across Davidson, Cornelius, and Huntersville?</h3>
        <p style="color:var(--ink-2);font-size:15px;margin-bottom:16px">Median rent by town, 2018–2024. Each line tracks what renters paid in that year's ACS survey.</p>
        <div class="card viz-host" id="rent-chart-host">
          <div class="card-t">Median Rent by Town (2018–2024)</div>
          <div class="card-s">Cornelius, Davidson, Huntersville</div>
          <div class="filterbar" style="margin-bottom:14px">
            <span style="font-size:13px;color:var(--ink-2);font-family:'Hanken Grotesk',sans-serif;margin-right:8px">Town:</span>
            <button class="chip on" data-rent-town="All">All towns</button>
            <button class="chip" data-rent-town="Cornelius">Cornelius</button>
            <button class="chip" data-rent-town="Davidson">Davidson</button>
            <button class="chip" data-rent-town="Huntersville">Huntersville</button>
          </div>
          <div id="rent-chart" style="width:100%"></div>
          <div class="callout"><div class="callout-t">A two-bedroom in Huntersville that rented for roughly $1,196 in 2018 now goes for $1,820, a 52% increase. Rent rose fastest in Cornelius and Huntersville after 2020, while Davidson (already the priciest) saw slower growth from a higher base.</div><div class="callout-s">Source: <span class="gloss-link" data-term="acs" role="button" tabindex="0" onclick="glossTerm('acs')">ACS</span> 2018–2024</div></div>
        </div>
      </div>

      <!-- Block 2: Home value trends -->
      <div style="margin-bottom:36px">
        <h3 style="font-family:'Newsreader',serif;font-size:22px;font-weight:400;margin-bottom:6px;color:var(--ink)">How have home prices changed, and is buying becoming out of reach?</h3>
        <p style="color:var(--ink-2);font-size:15px;margin-bottom:16px">Home values indexed to 2018 alongside median income, showing how ownership affordability has shifted.</p>
      </div>


      <!-- Chart 3: Home Value vs Income Growth -->
      <div class="card viz-host" id="home-value-chart-host" style="margin-top:22px">
        <div class="card-t">Home Value vs. Income Growth, Indexed to 2018</div>
        <div class="card-s">Home values have risen far faster than incomes, making ownership increasingly out of reach</div>
        <div class="filterbar" style="margin-bottom:14px">
          <span style="font-size:13px;color:var(--ink-2);font-family:'Hanken Grotesk',sans-serif;margin-right:8px">Town:</span>
          <button class="chip on" data-hv-town="All">All towns</button>
          <button class="chip" data-hv-town="Cornelius">Cornelius</button>
          <button class="chip" data-hv-town="Davidson">Davidson</button>
          <button class="chip" data-hv-town="Huntersville">Huntersville</button>
        </div>
        <div id="home-value-chart" style="width:100%"></div>
        <div class="callout"><div class="callout-t">In Cornelius, home values rose 91% between 2018 and 2024. Median incomes rose just 28% over the same period.</div><div class="callout-s">Source: <span class="gloss-link" data-term="acs" role="button" tabindex="0" onclick="glossTerm('acs')">ACS</span> 2018–2024</div></div>
      </div>


      <!-- Block 3: Housing wage -->
      <div style="margin-top:36px;margin-bottom:36px">
        <h3 style="font-family:'Newsreader',serif;font-size:22px;font-weight:400;margin-bottom:6px;color:var(--ink)">How much does someone need to earn per hour to afford rent without being cost-burdened?</h3>
        <p style="color:var(--ink-2);font-size:15px;margin-bottom:16px">The "housing wage" is the hourly pay a full-time worker needs so rent does not exceed 30% of income. No common local occupation reaches it.</p>
        <div class="card viz-host" style="margin-bottom:20px">
          <div class="card-t">Housing Wage vs. Most Common Local Occupations</div>
          <div class="card-s">Hourly wages for Charlotte-area occupations vs. the housing wage needed to afford a 2-bedroom without being cost-burdened</div>
          <div id="chart-housing-wage"></div>
          <div class="callout"><div class="callout-t">At $35.08/hr, the housing wage is out of reach for nearly every common occupation in the Charlotte area. Only registered nurses ($40.42/hr) earn enough — most workers in retail, food service, and logistics earn less than half the housing wage.</div><div class="callout-s">Source: NLIHC <em>Out of Reach</em> 2024 · BLS Occupational Employment &amp; Wages, Charlotte-Concord-Gastonia MSA 2023</div></div>
        </div>
        <!-- Block 4: Rent by bedroom size -->
        <div class="card viz-host">
          <div class="card-t">Fair Market Rent by Bedroom Size (2025)</div>
          <div class="card-s">HUD Fair Market Rents for Charlotte vs. Raleigh and Atlanta — how local rents compare across metro peers</div>
          <div id="chart-fmr-bedroom"></div>
          <div class="callout"><div class="callout-t">Charlotte's Fair Market Rents are broadly comparable to Atlanta's and below Raleigh's for smaller units, but the gap closes — and reverses for 4-bedroom units — as family size grows. A 4-bedroom unit in Charlotte runs $2,852/month, $309 above Atlanta.</div><div class="callout-s">Source: HUD FY2025 Fair Market Rents</div></div>
        </div>
      </div>


      <!-- Block 5: Affordability gap by income level -->
      <div style="margin-bottom:36px">
        <h3 style="font-family:'Newsreader',serif;font-size:22px;font-weight:400;margin-bottom:6px;color:var(--ink)">Who can afford to live in North Meck at different income levels?</h3>
        <p style="color:var(--ink-2);font-size:15px;margin-bottom:16px">Income limits and maximum affordable rent at each AMI bracket compared to fair market rent, showing the monthly gap households face at each income tier.</p>
        <div class="card viz-host">
          <div class="card-t">Affordable Rent vs. Fair Market Rent by AMI Bracket</div>
          <div class="card-s">Max affordable rent (30% of income rule) vs. HUD Fair Market Rent across bedroom sizes — Charlotte-Mecklenburg metro, FY2025</div>
          <div id="chart-ami-gap"></div>
          <div class="callout"><div class="callout-t">Households earning 30% or 50% of AMI face a severe monthly shortfall — they can afford far less than market rents require. Even at 80% AMI, most bedroom sizes remain out of reach. Only households at 100% AMI can afford the fair market rent for all unit sizes.</div><div class="callout-s">Source: HUD FY2025 Income Limits &amp; Fair Market Rents · Charlotte-Concord-Gastonia HUD Metro FMR Area</div></div>
        </div>
      </div>


      <!-- Block 6: Rent-to-income & home price-to-income ratios -->
      <div style="margin-bottom:36px">
        <h3 style="font-family:'Newsreader',serif;font-size:22px;font-weight:400;margin-bottom:6px;color:var(--ink)">How does rent — and homeownership — compare to what residents actually earn?</h3>
        <p style="color:var(--ink-2);font-size:15px;margin-bottom:16px">Rent-to-income ratio measures what share of median household income goes to rent. A home price-to-income ratio above 4× is considered unaffordable for first-time buyers without significant savings. Both ratios have climbed sharply since 2018.</p>
        <div class="g2" style="margin-bottom:16px">
          <div class="card viz-host" id="rti-chart-host">
            <div class="card-t">Rent-to-Income Ratio by Town (2018–2024)</div>
            <div class="card-s">Median rent ÷ median household income · 30% HUD threshold shown</div>
            <div class="filterbar" style="margin-bottom:14px">
              <span class="lbl">Town:</span>
              <button class="chip on" data-af-town="All">All towns</button>
              <button class="chip" data-af-town="Cornelius">Cornelius</button>
              <button class="chip" data-af-town="Davidson">Davidson</button>
              <button class="chip" data-af-town="Huntersville">Huntersville</button>
            </div>
            <div id="rti-chart" style="width:100%"></div>
            <div class="callout"><div class="callout-t">In all three towns, rent now consumes a larger share of household income than it did in 2018. The dashed line marks the 30% cost-burden threshold — once crossed, households have less to spend on food, healthcare, and savings.</div><div class="callout-s">Source: <span class="gloss-link" data-term="acs" role="button" tabindex="0" onclick="glossTerm('acs')">ACS</span> 2018–2024 · ratio = (median annual rent) ÷ (median household income)</div></div>
          </div>
          <div class="card viz-host" id="hpti-chart-host">
            <div class="card-t">Home Price-to-Income Ratio by Town (2018–2024)</div>
            <div class="card-s">Median home value ÷ median household income · 4× threshold shown</div>
            <div class="filterbar" style="margin-bottom:14px">
              <span class="lbl">Town:</span>
              <button class="chip on" data-af-town="All">All towns</button>
              <button class="chip" data-af-town="Cornelius">Cornelius</button>
              <button class="chip" data-af-town="Davidson">Davidson</button>
              <button class="chip" data-af-town="Huntersville">Huntersville</button>
            </div>
            <div id="hpti-chart" style="width:100%"></div>
            <div class="callout"><div class="callout-t">All three towns have crossed the 4× home price-to-income threshold, meaning a median-priced home now costs more than four years of median household income — well above the historical affordability benchmark for first-time buyers.</div><div class="callout-s">Source: <span class="gloss-link" data-term="acs" role="button" tabindex="0" onclick="glossTerm('acs')">ACS</span> 2018–2024 · ratio = median home value ÷ median household income</div></div>
          </div>
        </div>
      </div>


    </div>
  </div>

  <!-- TAB: supply -->
  <div class="tabpane" data-pane="supply">
    <div class="wrap">
      <div class="sec-head"><span class="eyebrow">Supply</span><h2 class="sec-h">Is there enough housing in North Meck, and is it the right kind?</h2></div>

      <!-- Population growth chart -->
      <div style="margin-bottom:36px">
        <h3 style="font-family:'Newsreader',serif;font-size:22px;font-weight:400;margin-bottom:6px;color:var(--ink)">How fast is North Meck growing, and is housing supply keeping up with population?</h3>
        <p style="color:var(--ink-2);font-size:15px;margin-bottom:16px">Total population by town, 2018–2024. Rapid growth increases demand for all housing types, particularly affordable rentals.</p>
        <div class="card viz-host" id="population-chart-host">
          <div class="card-t">Population Growth by Town (2018–2024)</div>
          <div class="card-s">Cornelius, Davidson, Huntersville</div>
          <div class="filterbar" style="margin-bottom:14px">
            <span style="font-size:13px;color:var(--ink-2);font-family:'Hanken Grotesk',sans-serif;margin-right:8px">Town:</span>
            <button class="chip on" data-pop-town="All">All towns</button>
            <button class="chip" data-pop-town="Cornelius">Cornelius</button>
            <button class="chip" data-pop-town="Davidson">Davidson</button>
            <button class="chip" data-pop-town="Huntersville">Huntersville</button>
          </div>
          <div id="population-chart" style="width:100%"></div>
          <div class="callout"><div class="callout-t">Huntersville added the most residents: its population grew by over 10,000 between 2018 and 2024. That kind of growth without matching affordable supply is a core driver of the cost pressure seen in the Affordability tab.</div><div class="callout-s">Source: <span class="gloss-link" data-term="acs" role="button" tabindex="0" onclick="glossTerm('acs')">ACS</span> 2018–2024</div></div>
        </div>

      </div>

      <div style="margin-bottom:28px">
        <!-- Block 1: Total housing units -->
        <div style="margin-bottom:0">
          <h3 style="font-family:'Newsreader',serif;font-size:20px;font-weight:400;margin-bottom:10px;color:var(--ink)">How many households are in each town, and how has that changed?</h3>
          <div class="card viz-host" id="tenure-chart-host">
            <div class="card-t">Total Households by Town (2018–2024)</div>
            <div class="card-s"></div>
            <div class="filterbar" style="margin-bottom:14px">
              <span style="font-size:13px;color:var(--ink-2);font-family:'Hanken Grotesk',sans-serif;margin-right:8px">Town:</span>
              <button class="chip on" data-tenure-town="All">All towns</button>
              <button class="chip" data-tenure-town="Cornelius">Cornelius</button>
              <button class="chip" data-tenure-town="Davidson">Davidson</button>
              <button class="chip" data-tenure-town="Huntersville">Huntersville</button>
            </div>
            <div id="tenure-chart" style="width:100%"><p style="color:#888;font-family:'Hanken Grotesk',sans-serif;padding:12px">Loading data…</p></div>
            <div class="callout"><div class="callout-t">Owner-occupied households dominate all three towns (70–80% of households), but Huntersville has added the most renter households in absolute terms since 2018, reflecting its rapid growth.</div><div class="callout-s">Source: <span class="gloss-link" data-term="acs" role="button" tabindex="0" onclick="glossTerm('acs')">ACS</span> 2018–2024</div></div>
          </div>
        </div>

      </div>

      <!-- Block 2: Housing types (full width) -->
      <div style="margin-bottom:28px">
        <h3 style="font-family:'Newsreader',serif;font-size:20px;font-weight:400;margin-bottom:10px;color:var(--ink)">What is the mix of single-family, multifamily, duplex, manufactured, and condo units?</h3>
        <div class="card viz-host" id="housing-types-host">
          <div class="card-t">Housing Types by Town (2024)</div>
          <div class="card-s">Share of housing units by structure type</div>
          <div id="housing-types-chart" style="width:100%"></div>
          <div class="callout"><div class="callout-t">All three towns are majority single-family, but Cornelius has the highest share of large multifamily (25%), reflecting its denser, more transit-accessible development pattern.</div><div class="callout-s">Source: <span class="gloss-link" data-term="acs" role="button" tabindex="0" onclick="glossTerm('acs')">ACS</span> 2024 · Table B25024</div></div>
        </div>
      </div>
      <div class="g2" style="display:none">

      </div>

      <div class="g2" style="margin-bottom:28px">
        <!-- Block 3: Age of housing stock -->
        <div style="margin-bottom:0">
          <h3 style="font-family:'Newsreader',serif;font-size:20px;font-weight:400;margin-bottom:10px;color:var(--ink)">How old is the housing, and what does that mean for maintenance and habitability?</h3>
          <div class="card" style="border:1px dashed var(--line-2);background:var(--paper-2)">
            <div class="card-t" style="color:var(--ink-2)">Age of housing stock</div>
            <div class="card-s">Grouped bar by decade of construction across North Meck towns</div>
            <div style="padding:28px 0;text-align:center;color:var(--ink-3)">
              <i class="ti ti-clock" style="font-size:22px;display:block;margin-bottom:8px"></i>
              <div style="font-size:14px;font-weight:500;color:var(--ink-2)">Coming soon</div>
              <div style="font-size:12px;margin-top:4px">Data source: ACS Table B25034 (needs Census pull)</div>
            </div>
          </div>
        </div>
        <!-- Block 4: Vacancy rates -->
        <div style="margin-bottom:0">
          <h3 style="font-family:'Newsreader',serif;font-size:20px;font-weight:400;margin-bottom:10px;color:var(--ink)">Is the rental market tight? Low vacancy means less bargaining power for renters.</h3>
          <div class="card" style="border:1px dashed var(--line-2);background:var(--paper-2)">
            <div class="card-t" style="color:var(--ink-2)">Vacancy rates over time</div>
            <div class="card-s">Line chart: vacancy rate by town, 2018–2024</div>
            <div style="padding:28px 0;text-align:center;color:var(--ink-3)">
              <i class="ti ti-clock" style="font-size:22px;display:block;margin-bottom:8px"></i>
              <div style="font-size:14px;font-weight:500;color:var(--ink-2)">Coming soon</div>
              <div style="font-size:12px;margin-top:4px">Data source: ACS Table B25004 (needs Census pull)</div>
            </div>
          </div>
        </div>
      </div>

      <div class="g2" style="margin-bottom:28px">
        <!-- Block 5: Subsidized units -->
        <div style="margin-bottom:0">
          <h3 style="font-family:'Newsreader',serif;font-size:20px;font-weight:400;margin-bottom:10px;color:var(--ink)">How many units in North Meck are subsidized, and how has that changed?</h3>
          <div class="card" style="border:1px dashed var(--line-2);background:var(--paper-2)">
            <div class="card-t" style="color:var(--ink-2)">Subsidized and affordable units</div>
            <div class="card-s">Bar chart: total vs. subsidized vs. units affordable at 80% AMI</div>
            <div style="padding:28px 0;text-align:center;color:var(--ink-3)">
              <i class="ti ti-clock" style="font-size:22px;display:block;margin-bottom:8px"></i>
              <div style="font-size:14px;font-weight:500;color:var(--ink-2)">Coming soon</div>
              <div style="font-size:12px;margin-top:4px">Data source: HUD Picture of Subsidized Households + LIHTC database</div>
            </div>
          </div>
        </div>
        <!-- Block 6: New construction -->
