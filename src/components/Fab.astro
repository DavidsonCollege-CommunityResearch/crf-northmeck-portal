<!-- ════ FAB ════ -->
<div class="fab" id="supportFab">
  <div class="fab-menu" role="menu" aria-label="Help and feedback">
    <div class="fab-menu-h">How can we help?</div>
    <button class="fab-item" role="menuitem" onclick="window.location='#'"><i class="ti ti-alert-triangle"></i>Report an issue?</button>
    <button class="fab-item" role="menuitem" onclick="window.location='#'"><i class="ti ti-message-dots"></i>Any feedback?</button>
    <button class="fab-item" role="menuitem" onclick="window.location='#'"><i class="ti ti-lifebuoy"></i>Support</button>
  </div>
  <button class="fab-btn" aria-label="Help &amp; feedback" aria-haspopup="true" onclick="toggleFab(event)">
    <i class="ti ti-message-dots fab-ic-open" style="font-size:26px"></i><i class="ti ti-x fab-ic-close" style="font-size:26px"></i>
  </button>
</div>
