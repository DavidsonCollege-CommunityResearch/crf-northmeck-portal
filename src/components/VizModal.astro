<!-- ════ VIZ EXPAND MODAL ════ -->
<div class="modal-bg" id="vizModal" onclick="if(event.target===this)closeVizModal()">
  <div class="modal viz-modal">
    <button class="modal-close" onclick="closeVizModal()" aria-label="Close">×</button>
    <div class="viz-modal-head"><i class="ti ti-chart-histogram"></i>Expanded view<button class="modal-share-btn" type="button" onclick="if(window.openSharePop&&window.__vizHost)window.openSharePop(this,window.__vizHost,'viz')"><i class="ti ti-share-2"></i> Share</button></div>
    <div id="vizBody"></div>
  </div>
</div>
