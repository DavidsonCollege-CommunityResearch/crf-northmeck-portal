<script type="module">
  import { MDConnection } from "https://cdn.jsdelivr.net/npm/@motherduck/wasm-client@1.5.4-r.1/+esm";
  const MD_TOKEN = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..g2FjvYtBsCNBMAHUG9ggxmu10dQRM2Q6iPyxK_5LaRc";
  window.__mdConn = (async () => {
    let lastErr;
    for (let attempt = 0; attempt <= 2; attempt++) {
      try {
        const conn = MDConnection.create({ mdToken: MD_TOKEN });
        await Promise.race([
          conn.evaluateQuery('SELECT 1'),
          new Promise((_, rej) => setTimeout(() => rej(new Error('MotherDuck connect verification timed out')), 10000))
        ]);
        return conn;
      } catch (err) {
        lastErr = err;
        console.error(`MotherDuck connect attempt ${attempt + 1} failed:`, err);
        if (attempt < 2) await new Promise(r => setTimeout(r, 900 * (attempt + 1)));
      }
    }
    throw lastErr;
  })();
</script>
